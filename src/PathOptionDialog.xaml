<Window x:Class="XTalkEdit.PathOptionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XTalkEdit"
        xmlns:p="clr-namespace:XTalkEdit.Properties"
        mc:Ignorable="d" Height="420" Width="400"
        Title="{x:Static p:Resources.PathOptions}" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen">

    <StackPanel Orientation="Vertical" Margin="8">
        <RadioButton x:Name="NextFrameOptButton" GroupName="PathOptions" Margin="8 24 8 8">
            <TextBlock FontSize="16" Text="{x:Static p:Resources.NextFrame}" />
        </RadioButton>

        <RadioButton x:Name="LabelOptButton" GroupName="PathOptions" Margin="8 24 8 8">
            <TextBlock FontSize="16" Text="{x:Static p:Resources.Label}" />
        </RadioButton>

        <ComboBox x:Name="LabelComboBox" IsEditable="True" FontSize="16"  Margin="28 8 8 8" GotFocus="LabelComboBox_GotFocus" />

        <RadioButton x:Name="WebPageOptButton" GroupName="PathOptions" Margin="8 24 8 8">
            <TextBlock FontSize="16" Text="{x:Static p:Resources.WebPage}" />
        </RadioButton>

        <TextBox x:Name="UrlTextBox" FontSize="14" Margin="28 8 8 8" GotFocus="UrlTextBox_GotFocus" />

        <StackPanel Orientation="Horizontal" Margin="28 8 8 8">
            <RadioButton x:Name="HrefSelfButton" GroupName="HrefTargets" IsChecked="True" Margin="0 0 16 0">
                <TextBlock FontSize="14" Text="{x:Static p:Resources.HrefSelf}" />
            </RadioButton>

            <RadioButton x:Name="HrefTopButton" GroupName="HrefTargets" Margin="0 0 16 0">
                <TextBlock FontSize="14" Text="{x:Static p:Resources.HrefTop}" />
            </RadioButton>

            <RadioButton x:Name="HrefBlankButton" GroupName="HrefTargets">
                <TextBlock FontSize="14" Text="{x:Static p:Resources.HrefBlank}" />
            </RadioButton>
        </StackPanel>
        
        <CheckBox x:Name="PackOptsCheckBox" Margin="28 8 8 24" IsChecked="True">
            <TextBlock FontSize="14" Text="{x:Static p:Resources.PackOptsMsg}" />
        </CheckBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Button x:Name="OkButton" Style="{StaticResource EditButtonStyle}" Content="{x:Static p:Resources.BtnOK}" Click="OkButton_Click" />
            <Button x:Name="CancelButton" Style="{StaticResource EditButtonStyle}" Content="{x:Static p:Resources.BtnCancel}" Click="CancelButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>
