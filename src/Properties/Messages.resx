  <data name="msgNewID" xml:space="preserve">
    <value>Please enter a new unique ID that is recommended to consist of alphabets, numbers, and underline.</value>
  </data>
  <data name="msgNewIDforFile" xml:space="preserve">
    <value>Please enter a unique ID for the newly added file. It is recommended to consist of alphabets, numbers, and underline.</value>
  </data>
  <data name="msgNewProjectName" xml:space="preserve">
    <value>Please enter a new project name as the newly created sub-directory in the current working directory.</value>
  </data>
  <data name="msgNewSceneName" xml:space="preserve">
    <value>Please enter a new scene script name. It will be the file title of newly created .xtalk file in the current project directory.</value>
  </data>
  <data name="msgNoMoreFrames" xml:space="preserve">
